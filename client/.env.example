# ─── SakshamAI Client Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values for production builds.
# In development, the CRA proxy in package.json handles API routing automatically.

# Only needed for production builds (when client and server are on different domains)
# Leave blank for local development.
# Example: https://sakshamai-api.onrender.com
REACT_APP_API_URL=
